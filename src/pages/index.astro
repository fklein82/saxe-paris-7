---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const img = (name: string) => `${base}images/${name}`;

const photos = [
  { src: img('salon-overview.jpg'), alt: 'Salon lumineux avec moulures haussmanniennes et cuisine ouverte' },
  { src: img('salon-dining.jpg'), alt: 'Espace repas avec table ronde et vue sur la cuisine' },
  { src: img('salon-sofa.jpg'), alt: 'Canapé confortable avec vue sur les arbres de l\'avenue' },
  { src: img('salon-evening.jpg'), alt: 'Ambiance du salon en soirée' },
  { src: img('kitchen.jpg'), alt: 'Cuisine équipée en bois et marbre' },
  { src: img('bedroom-double.jpg'), alt: 'Chambre avec lit double' },
  { src: img('bedroom-single.jpg'), alt: 'Chambre avec lit simple' },
  { src: img('bathroom-main.jpg'), alt: 'Salle de bain avec douche à l\'italienne' },
  { src: img('bathroom-washing.jpg'), alt: 'Salle de bain avec lave-linge' },
  { src: img('entrance.jpg'), alt: 'Entrée indépendante avec porte cochère' },
  { src: img('hallway.jpg'), alt: 'Couloir d\'entrée avec rangements' },
  { src: img('classic-doors.jpg'), alt: 'Portes vitrées classiques haussmanniennes' },
  { src: img('eiffel-tower-day.jpg'), alt: 'Vue sur la Tour Eiffel depuis le 7e arrondissement' },
  { src: img('eiffel-tower-night.jpg'), alt: 'Tour Eiffel illuminée vue depuis l\'avenue' },
];

const equipements = [
  { icon: '🍳', label: 'Cuisine équipée', detail: 'Four, plaques, micro-ondes' },
  { icon: '🫧', label: 'Lave-vaisselle', detail: '' },
  { icon: '☕', label: 'Machine Nespresso', detail: '' },
  { icon: '📺', label: 'Télévision', detail: '' },
  { icon: '📶', label: 'Wi-Fi fibre', detail: 'Haut débit' },
  { icon: '🛏️', label: 'Draps & serviettes', detail: 'Fournis' },
  { icon: '👕', label: 'Lave-linge', detail: '' },
  { icon: '🚪', label: 'Entrée indépendante', detail: 'Porte cochère sur l\'avenue' },
];

const recommandations = [
  { name: 'Le Ministère', type: 'Bistrot de quartier', desc: 'Cuisine maison et plats à emporter.', url: 'https://maps.app.goo.gl/nqh5ojrqBSLWu5AJ6?g_st=ic' },
  { name: 'Bistrot de Breteuil', type: 'Brasserie de quartier', desc: 'Une brasserie conviviale et authentique.', url: 'https://maps.app.goo.gl/GpxxZ2TJgSXDTbbr7?g_st=ic' },
  { name: 'Oui mon Général !', type: 'Brasserie gastronomique', desc: 'Excellente table. Réservation conseillée.', url: 'https://maps.app.goo.gl/KuYQdx6aFUM2krLx8?g_st=ic' },
  { name: 'Le Vauban', type: 'Café avec vue', desc: 'Idéal pour un café le matin, face aux Invalides.', url: 'https://maps.app.goo.gl/p9XXfToxym8StEAp6?g_st=ic' },
  { name: 'Boulangerie artisanale', type: 'Boulangerie', desc: 'Pain et viennoiseries d\'exception.', url: 'https://maps.app.goo.gl/wDwseX9nWKGXRMBx9?g_st=ic' },
  { name: 'Supermarché G20', type: 'Courses', desc: 'À deux pas, prix raisonnables.', url: 'https://maps.app.goo.gl/En1RK5dUyHMmMgtP6?g_st=ic' },
];
---

<Layout>
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 transition-all">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
      <a href="#" class="font-serif text-lg sm:text-xl font-semibold text-charcoal tracking-tight">
        Paris 7<sup>e</sup>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-warm-gray">
        <a href="#appartement" class="hover:text-gold transition-colors">L'appartement</a>
        <a href="#galerie" class="hover:text-gold transition-colors">Photos</a>
        <a href="#quartier" class="hover:text-gold transition-colors">Quartier</a>
        <a href="#disponibilites" class="hover:text-gold transition-colors">Disponibilités</a>
      </div>
      <a href="#contact" class="bg-gold text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-gold-light transition-colors">
        Réserver
      </a>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={img('salon-overview.jpg')}
        alt="Salon de l'appartement Paris 7e"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60"></div>
    </div>
    <div class="relative z-10 text-center text-white px-4 max-w-3xl mx-auto">
      <p class="text-sm sm:text-base uppercase tracking-[0.25em] mb-4 text-white/80 font-medium">Appartement meublé de charme</p>
      <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-tight mb-6">
        Paris 7<sup>e</sup>
      </h1>
      <p class="text-lg sm:text-xl text-white/90 mb-8 font-light max-w-xl mx-auto">
        Sur une belle avenue du 7<sup>e</sup> arrondissement, à deux pas de la Tour Eiffel et des Invalides.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contact" class="bg-gold hover:bg-gold-light text-white px-8 py-3.5 rounded-full text-base font-medium transition-colors">
          Réserver cet appartement
        </a>
        <a href="#appartement" class="border border-white/50 hover:bg-white/10 text-white px-8 py-3.5 rounded-full text-base font-medium transition-colors">
          Découvrir
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- L'appartement -->
  <section id="appartement" class="py-20 sm:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Bienvenue</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">L'appartement</h2>
        <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
        <p class="text-warm-gray text-lg max-w-2xl mx-auto leading-relaxed">
          Un bel appartement meublé de 3 pièces, entièrement rénové, situé au cœur du 7<sup>e</sup> arrondissement de Paris. Lumineux, calme et fonctionnel, il offre tout le confort d'un vrai chez-soi parisien.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 items-center mb-16">
        <div>
          <img src={img('salon-dining.jpg')} alt="Salon et coin repas" class="rounded-2xl shadow-lg w-full" loading="lazy" />
        </div>
        <div class="space-y-6">
          <h3 class="font-serif text-2xl text-charcoal">Un intérieur soigné</h3>
          <p class="text-warm-gray leading-relaxed">
            L'appartement allie le charme haussmannien — moulures, parquet, hauteur sous plafond — à une rénovation contemporaine avec une cuisine ouverte en bois et marbre, une salle de bain moderne et un mobilier de qualité.
          </p>
          <p class="text-warm-gray leading-relaxed">
            L'entrée est totalement indépendante, accessible directement depuis l'avenue via une belle porte cochère. Un vrai avantage pour votre intimité et votre confort.
          </p>
          <div class="flex items-center gap-2 text-gold font-medium">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            7<sup>e</sup> arrondissement de Paris
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Couchages -->
  <section class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Confort</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">Les couchages</h2>
        <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
          <div class="text-4xl mb-4">🛏️</div>
          <h3 class="font-serif text-xl mb-2">Chambre principale</h3>
          <p class="text-warm-gray">Grand lit double confortable, idéal pour un couple.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
          <div class="text-4xl mb-4">🛋️</div>
          <h3 class="font-serif text-xl mb-2">Chambre d'appoint</h3>
          <p class="text-warm-gray">Un lit simple dans un espace calme et cosy.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
          <div class="text-4xl mb-4">✨</div>
          <h3 class="font-serif text-xl mb-2">Couchages supplémentaires</h3>
          <p class="text-warm-gray">Lit d'appoint dépliable et matelas gonflables disponibles sur demande.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm max-w-2xl mx-auto text-center">
        <h3 class="font-serif text-2xl mb-4 text-charcoal">Capacité d'accueil</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-6 sm:gap-12 mb-4">
          <div>
            <p class="text-3xl font-serif text-gold mb-1">2-3</p>
            <p class="text-warm-gray text-sm">personnes<br><span class="font-medium text-charcoal">Confort optimal</span></p>
          </div>
          <div class="hidden sm:block w-px bg-gray-200"></div>
          <div>
            <p class="text-3xl font-serif text-gold mb-1">4-6</p>
            <p class="text-warm-gray text-sm">personnes<br><span class="font-medium text-charcoal">Configuration étendue</span></p>
          </div>
        </div>
        <p class="text-sm text-warm-gray mt-4">
          L'appartement est idéal pour 2 à 3 personnes. Il peut accueillir jusqu'à 6 personnes grâce aux couchages d'appoint, parfait pour un séjour en famille ou entre amis.
        </p>
      </div>
    </div>
  </section>

  <!-- Équipements -->
  <section class="py-20 sm:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Tout est prévu</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">Les équipements</h2>
        <div class="w-16 h-px bg-gold mx-auto"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {equipements.map(eq => (
          <div class="bg-cream rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl mb-3">{eq.icon}</div>
            <p class="font-medium text-charcoal text-sm">{eq.label}</p>
            {eq.detail && <p class="text-warm-gray text-xs mt-1">{eq.detail}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Galerie -->
  <section id="galerie" class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Visite virtuelle</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">Galerie photos</h2>
        <div class="w-16 h-px bg-gold mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {photos.map((photo, i) => (
          <button
            type="button"
            data-lightbox-trigger
            data-index={i}
            class:list={[
              "group relative overflow-hidden rounded-xl block cursor-pointer w-full",
              i === 0 ? "sm:col-span-2 sm:row-span-2" : ""
            ]}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover aspect-[4/3] group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-end">
              <p class="text-white text-sm p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 font-medium text-left">
                {photo.alt}
              </p>
            </div>
          </button>
        ))}
      </div>

      <!-- Lightbox -->
      <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm" role="dialog" aria-modal="true">
        <button id="lightbox-close" class="absolute top-4 right-4 z-10 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors" aria-label="Fermer">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <button id="lightbox-prev" class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors" aria-label="Photo précédente">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="lightbox-next" class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors" aria-label="Photo suivante">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </button>
        <div class="flex items-center justify-center w-full h-full p-4 sm:p-12">
          <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" />
        </div>
        <p id="lightbox-caption" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/80 text-sm font-medium bg-black/50 px-4 py-2 rounded-full max-w-md text-center"></p>
        <p id="lightbox-counter" class="absolute top-5 left-5 text-white/60 text-sm font-medium"></p>
      </div>
    </div>
  </section>

  <!-- Vidéo -->
  <section id="video" class="py-20 sm:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Immersion</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">Visite en vidéo</h2>
        <div class="w-16 h-px bg-gold mx-auto"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="flex justify-center">
          <div class="w-full max-w-[320px] rounded-[2rem] overflow-hidden shadow-2xl bg-charcoal ring-4 ring-gray-200/50">
            <video
              id="apartment-video"
              controls
              preload="metadata"
              playsinline
              poster={img('salon-overview.jpg')}
              class="w-full aspect-[9/16] object-cover"
            >
              <source src={img('visite-appartement.mp4')} type="video/mp4" />
              Votre navigateur ne supporte pas la lecture vidéo.
            </video>
          </div>
        </div>
        <div class="text-center md:text-left space-y-6">
          <h3 class="font-serif text-2xl text-charcoal">Parcourez l'appartement</h3>
          <p class="text-warm-gray leading-relaxed text-lg">
            Découvrez chaque pièce de l'appartement comme si vous y étiez. Cette visite guidée vous donne un aperçu complet du séjour, de la cuisine, des chambres et de la salle de bain.
          </p>
          <p class="text-warm-gray leading-relaxed">
            Appuyez sur lecture pour commencer la visite.
          </p>
          <a href="#contact" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-white px-8 py-3.5 rounded-full font-medium transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            Me contacter
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Le quartier -->
  <section id="quartier" class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Emplacement</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">Le quartier</h2>
        <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <div class="space-y-6">
          <p class="text-warm-gray leading-relaxed text-lg">
            L'appartement se situe sur l'une des plus belles avenues haussmanniennes du 7<sup>e</sup> arrondissement. Large et arborée, elle offre une <strong class="text-charcoal font-medium">perspective remarquable sur la Tour Eiffel</strong>.
          </p>
          <p class="text-warm-gray leading-relaxed text-lg">
            Chaque semaine, le quartier accueille l'un des <strong class="text-charcoal font-medium">marchés les plus réputés de Paris</strong>, où se mêlent produits frais, artisans et ambiance typiquement parisienne.
          </p>
          <p class="text-warm-gray leading-relaxed text-lg">
            Le quartier est résidentiel, calme et élégant. À quelques pas des Invalides et du Champ de Mars, c'est un lieu privilégié pour vivre Paris comme un Parisien.
          </p>
        </div>
        <div class="space-y-4">
          <img src={img('eiffel-tower-day.jpg')} alt="Vue Tour Eiffel depuis le 7e arrondissement" class="rounded-2xl shadow-lg w-full" loading="lazy" />
          <img src={img('eiffel-tower-night.jpg')} alt="Tour Eiffel de nuit depuis l'avenue" class="rounded-2xl shadow-lg w-full" loading="lazy" />
        </div>
      </div>

      <!-- Transports -->
      <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm mb-12">
        <h3 class="font-serif text-2xl text-charcoal mb-6 text-center">Transports à proximité</h3>
        <div class="grid sm:grid-cols-3 gap-6 text-center">
          <div class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#e0b53e] text-white font-bold text-sm mb-2">10</span>
            <p class="font-medium text-charcoal">Ségur</p>
            <p class="text-warm-gray text-sm">Ligne 10</p>
          </div>
          <div class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#68b4de] text-white font-bold text-sm mb-2">13</span>
            <p class="font-medium text-charcoal">Saint-François-Xavier</p>
            <p class="text-warm-gray text-sm">Ligne 13</p>
          </div>
          <div class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#76c882] text-white font-bold text-sm mb-2">6</span>
            <p class="font-medium text-charcoal">Sèvres — Lecourbe</p>
            <p class="text-warm-gray text-sm">Ligne 6</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bonnes adresses -->
  <section class="py-20 sm:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Nos coups de cœur</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">Bonnes adresses</h2>
        <div class="w-16 h-px bg-gold mx-auto"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recommandations.map(r => (
          <a href={r.url} target="_blank" rel="noopener noreferrer" class="group bg-cream rounded-xl p-6 hover:shadow-md transition-all hover:-translate-y-1">
            <p class="text-xs uppercase tracking-wider text-gold font-medium mb-2">{r.type}</p>
            <h3 class="font-serif text-lg text-charcoal mb-2 group-hover:text-gold transition-colors">{r.name}</h3>
            <p class="text-warm-gray text-sm leading-relaxed">{r.desc}</p>
            <p class="text-gold text-sm mt-3 font-medium flex items-center gap-1">
              Voir sur la carte
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Disponibilités -->
  <section id="disponibilites" class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3">Planifier</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6">Disponibilités</h2>
        <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
        <p class="text-warm-gray text-lg max-w-xl mx-auto">
