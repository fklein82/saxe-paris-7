  <!-- Le quartier -->
  <section id="quartier" class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3" data-i18n="hood.subtitle">Emplacement</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6" data-i18n="hood.title">Le quartier</h2>
        <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <div class="space-y-6">
          <p class="text-warm-gray leading-relaxed text-lg" data-i18n-html="hood.desc1">
            L'appartement se situe sur l'une des plus belles avenues haussmanniennes du 7<sup>e</sup> arrondissement. Large et arborée, elle offre une <strong class="text-charcoal font-medium">perspective remarquable sur la Tour Eiffel</strong>.
          </p>
          <p class="text-warm-gray leading-relaxed text-lg" data-i18n-html="hood.desc2">
            Chaque semaine, le quartier accueille l'un des <strong class="text-charcoal font-medium">marchés les plus réputés de Paris</strong>, où se mêlent produits frais, artisans et ambiance typiquement parisienne.
          </p>
          <p class="text-warm-gray leading-relaxed text-lg" data-i18n="hood.desc3">
            Le quartier est résidentiel, calme et élégant. À quelques pas des Invalides et du Champ de Mars, c'est un lieu privilégié pour vivre Paris comme un Parisien.
          </p>
        </div>
        <div class="space-y-4">
          <img src={img('eiffel-tower-day.jpg')} alt="Vue Tour Eiffel depuis le 7e arrondissement" class="rounded-2xl shadow-lg w-full" width="1600" height="1200" loading="lazy" />
          <img src={img('eiffel-tower-night.jpg')} alt="Tour Eiffel de nuit depuis l'avenue" class="rounded-2xl shadow-lg w-full" width="1600" height="1200" loading="lazy" />
        </div>
      </div>

