---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const img = (name: string) => `${base}images/${name}`;

const photos = [
  { src: img('salon-overview.jpg'), alt: 'Salon lumineux avec moulures haussmanniennes et cuisine ouverte', altEn: 'Bright living room with Haussmann mouldings and open kitchen', altMg: 'Efitrano fandraisam-bahiny mazava miaraka amin\'ny lakozia misokatra' },
  { src: img('salon-dining.jpg'), alt: 'Espace repas avec table ronde et vue sur la cuisine', altEn: 'Dining area with round table and kitchen view', altMg: 'Toerana fisakafoanana miaraka amin\'ny latabatra boribory' },
  { src: img('salon-sofa.jpg'), alt: 'Canapé confortable avec vue sur les arbres de l\'avenue', altEn: 'Comfortable sofa with view of the tree-lined avenue', altMg: 'Sofa mampiadana miaraka amin\'ny fijery ny hazo eny amin\'ny arabe' },
  { src: img('salon-evening.jpg'), alt: 'Ambiance du salon en soirée', altEn: 'Living room evening ambiance', altMg: 'Toe-javatra amin\'ny efitrano fandraisam-bahiny amin\'ny hariva' },
  { src: img('kitchen.jpg'), alt: 'Cuisine équipée en bois et marbre', altEn: 'Fully equipped wood and marble kitchen', altMg: 'Lakozia feno fitaovana hazo sy marbra' },
  { src: img('bedroom-double.jpg'), alt: 'Chambre avec lit double', altEn: 'Bedroom with double bed', altMg: 'Efitrano misy fandriana roa' },
  { src: img('bedroom-single.jpg'), alt: 'Chambre avec lit simple', altEn: 'Bedroom with single bed', altMg: 'Efitrano misy fandriana tokana' },
  { src: img('bathroom-main.jpg'), alt: 'Salle de bain avec douche à l\'italienne', altEn: 'Bathroom with walk-in shower', altMg: 'Efitrano fandroana misy douche italianina' },
  { src: img('bathroom-washing.jpg'), alt: 'Salle de bain avec lave-linge', altEn: 'Bathroom with washing machine', altMg: 'Efitrano fandroana misy milina fanasan-damba' },
  { src: img('entrance.jpg'), alt: 'Entrée indépendante avec porte cochère', altEn: 'Private entrance with carriage door', altMg: 'Fidirana manokana misy varavarana lehibe' },
  { src: img('hallway.jpg'), alt: 'Couloir d\'entrée avec rangements', altEn: 'Entrance hallway with storage', altMg: 'Lalantsara fidirana misy fitehirizana' },
  { src: img('classic-doors.jpg'), alt: 'Portes vitrées classiques haussmanniennes', altEn: 'Classic Haussmann glass doors', altMg: 'Varavarana fitaratra haussmannianina' },
  { src: img('eiffel-tower-day.jpg'), alt: 'Vue sur la Tour Eiffel depuis le 7e arrondissement', altEn: 'Eiffel Tower view from the 7th arrondissement', altMg: 'Fijery ny Tour Eiffel avy amin\'ny arrondissement faha-7' },
  { src: img('eiffel-tower-night.jpg'), alt: 'Tour Eiffel illuminée vue depuis l\'avenue', altEn: 'Illuminated Eiffel Tower seen from the avenue', altMg: 'Tour Eiffel mirehitra hita avy amin\'ny arabe' },
];

const equipements = [
  { icon: '🍳', label: 'Cuisine équipée', labelEn: 'Fully equipped kitchen', detail: 'Four, plaques, micro-ondes', detailEn: 'Oven, hob, microwave' },
  { icon: '🫧', label: 'Lave-vaisselle', labelEn: 'Dishwasher', detail: '', detailEn: '' },
  { icon: '☕', label: 'Machine Nespresso', labelEn: 'Nespresso machine', detail: '', detailEn: '' },
  { icon: '📺', label: 'Télévision', labelEn: 'Television', detail: '', detailEn: '' },
  { icon: '📶', label: 'Wi-Fi fibre', labelEn: 'Fibre Wi-Fi', detail: 'Haut débit', detailEn: 'High speed' },
  { icon: '🛏️', label: 'Draps & serviettes', labelEn: 'Sheets & towels', detail: 'Fournis', detailEn: 'Provided' },
  { icon: '👕', label: 'Lave-linge', labelEn: 'Washing machine', detail: '', detailEn: '' },
  { icon: '🚪', label: 'Entrée indépendante', labelEn: 'Private entrance', detail: 'Porte cochère sur l\'avenue', detailEn: 'Carriage door on the avenue' },
];

const recommandations = [
  { name: 'Le Ministère', type: 'Bistrot de quartier', typeEn: 'Local bistro', desc: 'Cuisine maison et plats à emporter.', descEn: 'Home cooking and takeaway.', url: 'https://maps.app.goo.gl/nqh5ojrqBSLWu5AJ6?g_st=ic' },
  { name: 'Bistrot de Breteuil', type: 'Brasserie de quartier', typeEn: 'Local brasserie', desc: 'Une brasserie conviviale et authentique.', descEn: 'A friendly and authentic brasserie.', url: 'https://maps.app.goo.gl/GpxxZ2TJgSXDTbbr7?g_st=ic' },
  { name: 'Oui mon Général !', type: 'Brasserie gastronomique', typeEn: 'Gourmet brasserie', desc: 'Excellente table. Réservation conseillée.', descEn: 'Excellent dining. Reservation recommended.', url: 'https://maps.app.goo.gl/KuYQdx6aFUM2krLx8?g_st=ic' },
  { name: 'Le Vauban', type: 'Café avec vue', typeEn: 'Café with a view', desc: 'Idéal pour un café le matin, face aux Invalides.', descEn: 'Perfect for morning coffee, facing Les Invalides.', url: 'https://maps.app.goo.gl/p9XXfToxym8StEAp6?g_st=ic' },
  { name: 'Boulangerie artisanale', type: 'Boulangerie', typeEn: 'Bakery', desc: 'Pain et viennoiseries d\'exception.', descEn: 'Exceptional bread and pastries.', url: 'https://maps.app.goo.gl/wDwseX9nWKGXRMBx9?g_st=ic' },
  { name: 'Supermarché G20', type: 'Courses', typeEn: 'Groceries', desc: 'À deux pas, prix raisonnables.', descEn: 'A stone\'s throw away, reasonable prices.', url: 'https://maps.app.goo.gl/En1RK5dUyHMmMgtP6?g_st=ic' },
];
---

<Layout>
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 transition-all">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
      <a href="#" class="font-serif text-lg sm:text-xl font-semibold text-charcoal tracking-tight">
        Stay in Paris 7<sup>e</sup>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-warm-gray">
        <a href="#appartement" class="hover:text-gold transition-colors" data-i18n="nav.apartment">L'appartement</a>
        <a href="#galerie" class="hover:text-gold transition-colors" data-i18n="nav.photos">Photos</a>
        <a href="#video" class="hover:text-gold transition-colors" data-i18n="nav.video">Vidéo</a>
        <a href="#quartier" class="hover:text-gold transition-colors" data-i18n="nav.neighborhood">Quartier</a>
        <a href="#tarifs" class="hover:text-gold transition-colors" data-i18n="nav.rates">Tarifs</a>
        <a href="#disponibilites" class="hover:text-gold transition-colors" data-i18n="nav.availability">Disponibilités</a>
        <a href="#contact" class="hover:text-gold transition-colors">Contact</a>
      </div>
      <div class="flex items-center gap-3">
        <!-- Language switcher -->
        <div class="relative" id="lang-switcher">
          <button id="lang-toggle" class="flex items-center gap-1.5 text-sm font-medium text-warm-gray hover:text-gold transition-colors px-2.5 py-1.5 rounded-lg border border-gray-200 hover:border-gold" aria-label="Switch language" aria-expanded="false">
            <span id="lang-flag">🇫🇷</span>
            <span id="lang-label">FR</span>
            <svg class="w-3.5 h-3.5 transition-transform" id="lang-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div id="lang-dropdown" class="absolute right-0 top-full mt-1 bg-white rounded-xl shadow-lg border border-gray-100 py-1 min-w-[160px] hidden z-50 overflow-hidden">
            <button data-lang="fr" class="lang-option flex items-center gap-3 w-full px-4 py-2.5 text-sm text-left hover:bg-cream transition-colors">
              <span class="text-base">🇫🇷</span>
              <span class="font-medium text-charcoal">Français</span>
            </button>
            <button data-lang="en" class="lang-option flex items-center gap-3 w-full px-4 py-2.5 text-sm text-left hover:bg-cream transition-colors">
              <span class="text-base">🇬🇧</span>
              <span class="font-medium text-charcoal">English</span>
            </button>
            <button data-lang="mg" class="lang-option flex items-center gap-3 w-full px-4 py-2.5 text-sm text-left hover:bg-cream transition-colors">
              <span class="text-base">🇲🇬</span>
              <span class="font-medium text-charcoal">Malagasy</span>
            </button>
          </div>
        </div>
        <a href="#contact" class="bg-gold text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-gold-light transition-colors" data-i18n="nav.book">
          Réserver
        </a>
        <button id="menu-toggle" class="md:hidden p-2 text-charcoal hover:text-gold transition-colors" aria-label="Ouvrir le menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white/95 backdrop-blur-md">
      <div class="flex flex-col px-6 py-4 gap-3 text-sm font-medium text-warm-gray">
        <a href="#appartement" class="py-2 hover:text-gold transition-colors mobile-menu-link" data-i18n="nav.apartment">L'appartement</a>
        <a href="#galerie" class="py-2 hover:text-gold transition-colors mobile-menu-link" data-i18n="nav.photos">Photos</a>
        <a href="#video" class="py-2 hover:text-gold transition-colors mobile-menu-link" data-i18n="nav.video">Vidéo</a>
        <a href="#quartier" class="py-2 hover:text-gold transition-colors mobile-menu-link" data-i18n="nav.neighborhood">Quartier</a>
        <a href="#tarifs" class="py-2 hover:text-gold transition-colors mobile-menu-link" data-i18n="nav.rates">Tarifs</a>
        <a href="#disponibilites" class="py-2 hover:text-gold transition-colors mobile-menu-link" data-i18n="nav.availability">Disponibilités</a>
        <a href="#contact" class="py-2 hover:text-gold transition-colors mobile-menu-link">Contact</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={img('salon-overview.jpg')}
        alt="Salon de l'appartement Paris 7e"
        class="w-full h-full object-cover"
        width="1600"
        height="1200"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60"></div>
    </div>
    <div class="relative z-10 text-center text-white px-4 max-w-3xl mx-auto">
      <p class="text-sm sm:text-base uppercase tracking-[0.25em] mb-4 text-white/80 font-medium" data-i18n="hero.subtitle">Appartement meublé de charme</p>
      <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-tight mb-6">
        Paris 7<sup>e</sup>
      </h1>
      <p class="text-lg sm:text-xl text-white/90 mb-8 font-light max-w-xl mx-auto" data-i18n-html="hero.desc">
        Sur une belle avenue du 7<sup>e</sup> arrondissement, à deux pas de la Tour Eiffel et des Invalides.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contact" class="bg-gold hover:bg-gold-light text-white px-8 py-3.5 rounded-full text-base font-medium transition-colors" data-i18n="hero.cta">
          Réserver cet appartement
        </a>
        <a href="#appartement" class="border border-white/50 hover:bg-white/10 text-white px-8 py-3.5 rounded-full text-base font-medium transition-colors" data-i18n="hero.discover">
          Découvrir
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- L'appartement -->
  <section id="appartement" class="py-20 sm:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3" data-i18n="apt.welcome">Bienvenue</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6" data-i18n="apt.title">L'appartement</h2>
        <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
        <p class="text-warm-gray text-lg max-w-2xl mx-auto leading-relaxed" data-i18n-html="apt.desc">
          Un bel appartement meublé de 3 pièces, entièrement rénové, situé au cœur du 7<sup>e</sup> arrondissement de Paris. Lumineux, calme et fonctionnel, il offre tout le confort d'un vrai chez-soi parisien.
        </p>
      </div>

      <!-- Chiffres clés -->
      <div class="flex flex-wrap justify-center gap-6 sm:gap-10 mb-16">
        <div class="text-center">
          <p class="text-2xl sm:text-3xl font-serif text-gold">3</p>
          <p class="text-warm-gray text-sm" data-i18n="apt.rooms">pièces</p>
        </div>
        <div class="hidden sm:block w-px bg-gray-200"></div>
        <div class="text-center">
          <p class="text-2xl sm:text-3xl font-serif text-gold">2</p>
          <p class="text-warm-gray text-sm" data-i18n="apt.bedrooms">chambres</p>
        </div>
        <div class="hidden sm:block w-px bg-gray-200"></div>
        <div class="text-center">
          <p class="text-2xl sm:text-3xl font-serif text-gold">56m²</p>
          <p class="text-warm-gray text-sm" data-i18n="apt.area">surface</p>
        </div>
        <div class="hidden sm:block w-px bg-gray-200"></div>
        <div class="text-center">
          <p class="text-2xl sm:text-3xl font-serif text-gold">2-6</p>
          <p class="text-warm-gray text-sm" data-i18n="apt.guests">personnes</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 items-center mb-16">
        <div>
          <img src={img('salon-dining.jpg')} alt="Salon et coin repas" class="rounded-2xl shadow-lg w-full" width="1600" height="1200" loading="lazy" />
        </div>
        <div class="space-y-6">
          <h3 class="font-serif text-2xl text-charcoal" data-i18n="apt.interior_title">Un intérieur soigné</h3>
          <p class="text-warm-gray leading-relaxed" data-i18n="apt.interior_desc1">
            L'appartement allie le charme haussmannien — moulures, parquet, hauteur sous plafond — à une rénovation contemporaine avec une cuisine ouverte en bois et marbre, une salle de bain moderne et un mobilier de qualité.
          </p>
          <p class="text-warm-gray leading-relaxed" data-i18n="apt.interior_desc2">
            L'entrée est totalement indépendante, accessible directement depuis l'avenue via une belle porte cochère. Un vrai avantage pour votre intimité et votre confort.
          </p>
          <div class="flex items-center gap-2 text-gold font-medium">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span data-i18n-html="apt.location">7<sup>e</sup> arrondissement de Paris</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Couchages -->
  <section class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3" data-i18n="sleep.subtitle">Confort</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6" data-i18n="sleep.title">Les couchages</h2>
        <div class="w-16 h-px bg-gold mx-auto mb-8"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
          <div class="text-4xl mb-4">🛏️</div>
          <h3 class="font-serif text-xl mb-2" data-i18n="sleep.main_title">Chambre principale</h3>
          <p class="text-warm-gray" data-i18n="sleep.main_desc">Grand lit double confortable, idéal pour un couple.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
          <div class="text-4xl mb-4">🛋️</div>
          <h3 class="font-serif text-xl mb-2" data-i18n="sleep.second_title">Chambre d'appoint</h3>
          <p class="text-warm-gray" data-i18n="sleep.second_desc">Un lit simple dans un espace calme et cosy.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
          <div class="text-4xl mb-4">✨</div>
          <h3 class="font-serif text-xl mb-2" data-i18n="sleep.extra_title">Couchages supplémentaires</h3>
          <p class="text-warm-gray" data-i18n="sleep.extra_desc">Lit d'appoint dépliable et matelas gonflables disponibles sur demande.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm max-w-2xl mx-auto text-center">
        <h3 class="font-serif text-2xl mb-4 text-charcoal" data-i18n="sleep.capacity_title">Capacité d'accueil</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-6 sm:gap-12 mb-4">
          <div>
            <p class="text-3xl font-serif text-gold mb-1">2-3</p>
            <p class="text-warm-gray text-sm" data-i18n-html="sleep.optimal">personnes<br><span class="font-medium text-charcoal">Confort optimal</span></p>
          </div>
          <div class="hidden sm:block w-px bg-gray-200"></div>
          <div>
            <p class="text-3xl font-serif text-gold mb-1">4-6</p>
            <p class="text-warm-gray text-sm" data-i18n-html="sleep.extended">personnes<br><span class="font-medium text-charcoal">Configuration étendue</span></p>
          </div>
        </div>
        <p class="text-sm text-warm-gray mt-4" data-i18n="sleep.capacity_desc">
          L'appartement est idéal pour 2 à 3 personnes. Il peut accueillir jusqu'à 6 personnes grâce aux couchages d'appoint, parfait pour un séjour en famille ou entre amis.
        </p>
      </div>
    </div>
  </section>

  <!-- Équipements -->
  <section class="py-20 sm:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3" data-i18n="equip.subtitle">Tout est prévu</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6" data-i18n="equip.title">Les équipements</h2>
        <div class="w-16 h-px bg-gold mx-auto"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {equipements.map((eq, i) => (
          <div class="bg-cream rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl mb-3">{eq.icon}</div>
            <p class="font-medium text-charcoal text-sm" data-i18n={`equip.item${i}.label`}>{eq.label}</p>
            {eq.detail && <p class="text-warm-gray text-xs mt-1" data-i18n={`equip.item${i}.detail`}>{eq.detail}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3" data-i18n="reviews.subtitle">Témoignages</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6" data-i18n="reviews.title">Ce qu'en disent nos voyageurs</h2>
        <div class="w-16 h-px bg-gold mx-auto"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="flex gap-1 mb-4 text-gold">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
