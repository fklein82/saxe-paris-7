  <!-- Galerie -->
  <section id="galerie" class="py-20 sm:py-28 bg-cream px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold uppercase tracking-[0.2em] text-sm font-medium mb-3" data-i18n="gallery.subtitle">Visite virtuelle</p>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-charcoal mb-6" data-i18n="gallery.title">Galerie photos</h2>
        <div class="w-16 h-px bg-gold mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {photos.map((photo, i) => (
          <button
            type="button"
            data-lightbox-trigger
            data-index={i}
            class:list={[
              "group relative overflow-hidden rounded-xl block cursor-pointer w-full",
              i === 0 ? "sm:col-span-2 sm:row-span-2" : ""
            ]}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              data-alt-fr={photo.alt}
              data-alt-en={photo.altEn}
              data-alt-mg={photo.altMg}
              class="w-full h-full object-cover aspect-[4/3] group-hover:scale-105 transition-transform duration-500"
              width="1600"
              height="1200"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-end">
              <p class="text-white text-sm p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 font-medium text-left photo-caption">
                {photo.alt}
              </p>
            </div>
          </button>
        ))}
      </div>

      <!-- Lightbox -->
      <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm" role="dialog" aria-modal="true">
        <button id="lightbox-close" class="absolute top-4 right-4 z-10 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors" aria-label="Fermer">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <button id="lightbox-prev" class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors" aria-label="Photo précédente">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="lightbox-next" class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors" aria-label="Photo suivante">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </button>
        <div class="flex items-center justify-center w-full h-full p-4 sm:p-12">
          <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" />
        </div>
        <p id="lightbox-caption" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/80 text-sm font-medium bg-black/50 px-4 py-2 rounded-full max-w-md text-center"></p>
        <p id="lightbox-counter" class="absolute top-5 left-5 text-white/60 text-sm font-medium"></p>
      </div>
    </div>
  </section>

  <!-- Vidéo -->
