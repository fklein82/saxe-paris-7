---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const {
  title = "Appartement meublé Paris 7e — Proche Tour Eiffel et Invalides",
  description = "Bel appartement meublé 3 pièces à louer, Paris 7e arrondissement. Vue Tour Eiffel, quartier résidentiel prestigieux, entièrement équipé. Idéal 2-3 personnes."
} = Astro.props;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${base}images/salon-overview.jpg`} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
</head>
<body class="antialiased">
  <slot />
</body>
</html>
