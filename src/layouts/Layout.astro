---
import '../styles/global.css'

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Appartement meublé Paris 7e — Proche Tour Eiffel et Invalides</title>
  <meta name="description" content="Bel appartement meublé 3 pièces à louer, Paris 7e arrondissement. Vue Tour Eiffel, quartier résidentiel prestigieux, entièrement équipé. Idéal 2-3 personnes." />

  <!-- Open Graph -->
  <meta property="og:title" content="Appartement meublé Paris 7e — Proche Tour Eiffel et Invalides" />
  <meta property="og:description" content="Bel appartement meublé 3 pièces à louer, Paris 7e arrondissement. Vue Tour Eiffel, quartier résidentiel prestigieux, entièrement équipé. Idéal 2-3 personnes." />
  <meta property="og:image" content="https://www.stayinparis7.fr/images/salon-overview.jpg" />
  <meta property="og:url" content="https://www.stayinparis7.fr" />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:locale:alternate" content="en_GB" />
  <meta property="og:locale:alternate" content="mg_MG" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MZ1JR8RW5K"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MZ1JR8RW5K');
  </script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

  <!-- Dynamic SEO per language -->
  <script is:inline>
    (function() {
      const seo = {
        fr: { title: 'Appartement meublé Paris 7e — Proche Tour Eiffel et Invalides', desc: 'Bel appartement meublé 3 pièces à louer, Paris 7e arrondissement. Vue Tour Eiffel, quartier résidentiel prestigieux, entièrement équipé. Idéal 2-3 personnes.' },
        en: { title: 'Furnished apartment Paris 7th — Near Eiffel Tower and Invalides', desc: 'Beautiful 3-room furnished apartment for rent, Paris 7th arrondissement. Eiffel Tower view, prestigious residential area, fully equipped. Ideal for 2-3 guests.' },
        mg: { title: 'Trano misy fanaka Paris 7e — Akaikin\'ny Tour Eiffel sy Invalides', desc: 'Trano tsara tarehy misy efitrano 3 hofaina, arrondissement faha-7 Paris. Fijery Tour Eiffel, faritra fonenan\'olona, feno fitaovana. Mety ho an\'ny olona 2-3.' }
      };
      const lang = localStorage.getItem('lang') || 'fr';
      const s = seo[lang] || seo.fr;
      document.title = s.title;
      const descMeta = document.querySelector('meta[name="description"]');
      if (descMeta) descMeta.content = s.desc;
      const ogTitle = document.querySelector('meta[property="og:title"]');
      if (ogTitle) ogTitle.content = s.title;
      const ogDesc = document.querySelector('meta[property="og:description"]');
      if (ogDesc) ogDesc.content = s.desc;
      document.documentElement.lang = lang;
    })();
  </script>
</head>
<body class="antialiased">
  <slot />
</body>
</html>
